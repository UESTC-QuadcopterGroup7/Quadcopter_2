    CPU_INT32U  odd_cnt;
    CPU_INT32U  result;


    odd_cnt  = (value >> 1u) & 0x55555555u;  
    result   =  value - odd_cnt;                                 

    even_cnt =  result & 0x33333333u;        
    odd_cnt  = (result >> 2u) & 0x33333333u;
    result   =  even_cnt + odd_cnt;

    even_cnt =  result & 0x0F0F0F0Fu;        
    odd_cnt  = (result >> 4u) & 0x0F0F0F0Fu;
    result   =  even_cnt + odd_cnt;

    result = (result * 0x01010101u) >> 24u;

    return ((CPU_INT08U)result);
}














 

